# Contact email for Crossref/DataCite polite-pool access
CONTACT_EMAIL=your.email@example.com

# Optional: GitHub token for elevated API rate limits in governance lookups
GITHUB_TOKEN=

# Optional: OpenAIRE Graph API token (only needed for API fallback mode)
OPENAIRE_TOKEN=

# Zenodo dump version pin (DOI or version string)
OPENAIRE_DUMP_DOI=10.5281/zenodo.13430566

# Concurrency
MAX_CONCURRENT_REQUESTS=10
